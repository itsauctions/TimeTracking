{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Workday Time Tracker",
  "version": "0.2.0",
  "identifier": "local.workday-time-tracker",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Workday Time Tracker",
        "width": 920,
        "height": 680,
        "minWidth": 760,
        "minHeight": 560
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
