{
  "name": "workday-time-tracker",
  "version": "0.2.0",
  "description": "A small desktop workday timer with SQLite storage and XLSX export.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "postinstall": "electron-rebuild",
    "make:icon": "node scripts/make-ico.js",
    "make:icon:mac": "node scripts/make-mac-icon.js",
    "make:icons": "npm run make:icon && npm run make:icon:mac",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "package:mac": "electron-builder --mac dmg zip --universal",
    "package:win": "electron-builder --win portable",
    "package:win:wsl": "electron-builder --win portable -c.win.signAndEditExecutable=false"
  },
  "keywords": [
    "time-tracking",
    "sqlite",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@tauri-apps/cli": "^2.6.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "better-sqlite3": "^12.11.1"
  },
  "build": {
    "appId": "local.workday-time-tracker",
    "productName": "Workday Time Tracker",
    "icon": "assets/app-icon.png",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/**/*.node"
    ],
    "win": {
      "icon": "assets/app-icon.ico",
      "target": "portable"
    },
    "mac": {
      "icon": "assets/app-icon.icns",
      "category": "public.app-category.productivity",
      "extendInfo": {
        "NSCameraUsageDescription": "Workday Time Tracker can use the camera locally to pause tracking when you step away."
      },
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
