{
  "name": "workday-time-tracker",
  "version": "0.1.0",
  "description": "A small desktop workday timer with SQLite storage and on-demand CSV export.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "postinstall": "electron-rebuild",
    "make:icon": "node scripts/make-ico.js",
    "package:win": "electron-builder --win portable"
  },
  "keywords": [
    "time-tracking",
    "sqlite",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "better-sqlite3": "^11.1.2"
  },
  "build": {
    "appId": "local.workday-time-tracker",
    "productName": "Workday Time Tracker",
    "icon": "assets/app-icon.png",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/app-icon.ico",
      "target": "portable"
    }
  }
}
